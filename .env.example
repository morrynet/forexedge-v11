# ═══════════════════════════════════════════════════════════════════════════════
# ForexEdge v3 — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Core App ──────────────────────────────────────────────────────────────────
SECRET_KEY=generate-with-python-secrets-token-hex-32
DEBUG=false
PORT=5000

# Public store URL (no trailing slash)
STORE_URL=https://yourstore.onrender.com

# HTTPS flag — ALWAYS set to true in production
HTTPS=true

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (production — required for concurrent writes)
DATABASE_URL=postgresql://user:password@host:5432/forexedge

# SQLite path (dev/testing only)
# DB_PATH=saas.db

# ── Redis (required for multi-worker rate limiting + bot conversation history)
REDIS_URL=redis://your-redis-host:6379

# ── Admin Credentials ─────────────────────────────────────────────────────────
ADMIN_USER=admin

# REQUIRED: hash your password before storing it here
# Generate with: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
ADMIN_PASS_HASH=pbkdf2:sha256:260000$...your-hash-here...

# DEPRECATED: fallback plaintext (insecure — use ADMIN_PASS_HASH above)
# ADMIN_PASS=your-plaintext-password

# ── API Keys — one per service ────────────────────────────────────────────────
# Customer service bot
BOT_API_KEY=generate-a-long-random-secret-here

# Marketing userbot
USERBOT_API_KEY=generate-a-different-random-secret-here

# Legacy single key (still accepted, but prefer per-service above)
# API_SECRET=legacy-shared-key

# Cron job key (for /cron/monthly-audit endpoint)
CRON_KEY=generate-another-random-secret-here

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_BUTTON_URL=https://www.paypal.com/ncp/payment/YOUR_BUTTON_ID
# CRITICAL: Set this to your actual PayPal merchant email
PAYPAL_RECEIVER_EMAIL=your-paypal@email.com
PAYPAL_SANDBOX=false

# ── Referral / Payout Config ──────────────────────────────────────────────────
REFERRAL_COMMISSION_USD=5.00
ADMIN_EMAIL=morrynet@gmail.com

# ── Email (for monthly referral audit reports) ────────────────────────────────
# Gmail: enable "App Passwords" in Google account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# ── Download Token TTL ────────────────────────────────────────────────────────
DOWNLOAD_TOKEN_TTL_DAYS=30

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# Admin Telegram user IDs (comma-separated) — can use /stats command
ADMIN_TELEGRAM_IDS=123456789,987654321

# ── Telegram Userbot (Telethon) ───────────────────────────────────────────────
TELEGRAM_API_ID=your-api-id-from-my.telegram.org
TELEGRAM_API_HASH=your-api-hash
TELEGRAM_PHONE=+254700000000
SESSION_FILE=/data/userbot_session
STATE_DB=/data/userbot_state.db

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Userbot Safety Limits ─────────────────────────────────────────────────────
DM_PER_DAY_MAX=10       # Start at 10, increase to 20 after 2 weeks, 50 after a month
DM_DELAY_MIN=90         # Minimum seconds between DMs
DM_DELAY_MAX=240        # Maximum seconds between DMs
GROUP_MSG_DELAY_SEC=900 # Min 15 min between posts in the same group
JOIN_DELAY_SEC=60       # Seconds to wait between joining groups
CHANNEL_POST_INTERVAL_SEC=21600  # 6 hours between own-channel posts
